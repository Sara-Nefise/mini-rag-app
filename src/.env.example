APP_NAME="mini-RAG"
APP_VERSION="0.1"
OPENAI_API_KEY=""

FILE_ALLOWED_TYPES=["text/plain", "application/pdf"]
FILE_MAX_SIZE=10
FILE_DEFAULT_CHUNK_SIZE=512000 # 512KB

POSTGRES_USERNAME="postgres"
POSTGRES_PASSWORD="PASSWORD"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_MAIN_DATABASE="minirag"

# ========================= LLM Config =========================
GENERATION_BACKEND =
# OPENAI | COHERE | SENTENCE_TRANSFORMERS (local HF model, e.g. intfloat/multilingual-e5-large)
EMBEDDING_BACKEND =

OPENAI_API_KEY=""
OPENAI_API_URL=
COHERE_API_KEY=""

GENERATION_MODEL_ID="gpt-3.5-turbo-0125"
# Local HF embeddings (set EMBEDDING_BACKEND=SENTENCE_TRANSFORMERS):
EMBEDDING_MODEL_ID=intfloat/multilingual-e5-large
EMBEDDING_MODEL_SIZE=1024
EMBEDDING_INPUT_MAX_CHARS=12000
# multilingual-e5 max seq ~512 tokens; use ~8000 if using OpenAI/OpenRouter embeddings API
EMBEDDING_MAX_INPUT_TOKENS=512
EMBEDDING_BATCH_SIZE=8
# EMBEDDING_DEVICE=cuda:0

INPUT_DAFAULT_MAX_CHARACTERS=1024
GENERATION_DAFAULT_MAX_TOKENS=200
GENERATION_DAFAULT_TEMPERATURE=0.1

# ========================= Vector DB Config =========================
# QDRANT (local folder under src/assets/database/<VECTOR_DB_PATH>) | PGVECTOR (Postgres + pgvector)
VECTOR_DB_BACKEND=PGVECTOR
VECTOR_DB_PATH=minirag_qdrant
VECTOR_DB_DISTANCE_METHOD=cosine

# ========================= Template Configs =========================
PRIMARY_LANG = "en"
DEFAULT_LANG = "en"
FIREBASE_CREDENTIALS_PATH = "firebase_credentials.json"

# ----- OpenRouter (OpenAI-compatible API) -----
# Use one provider string for both backends; route traffic via base URL + OpenRouter key.
# GENERATION_BACKEND=OPENAI
# EMBEDDING_BACKEND=OPENAI
# OPENAI_API_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-REPLACE_ME
# GENERATION_MODEL_ID=openai/gpt-4o-mini
# EMBEDDING_MODEL_ID=openai/text-embedding-3-small
# EMBEDDING_MODEL_SIZE=1536
# Optional OpenRouter attribution headers:
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=mini-rag-app